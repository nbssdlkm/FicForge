{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "domain/**/*.ts",
    "prompts/**/*.ts",
    "services/**/*.ts",
    "repositories/**/*.ts",
    "llm/**/*.ts",
    "tokenizer/**/*.ts",
    "vector/**/*.ts",
    "platform/**/*.ts",
    "sync/**/*.ts",
    "fonts/**/*.ts",
    "index.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
